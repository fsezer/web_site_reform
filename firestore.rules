rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return request.auth.token.email;
    }

    function isLockedAdmin() {
      return email() == 'admin@istiklalyazilim.com';
    }

    function isListedAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/settings/admins)
        && email() in get(/databases/$(database)/documents/settings/admins).data.emails;
    }

    function isAdmin() {
      return isLockedAdmin()
        || email() == 'fsezer.mail@gmail.com'
        || isListedAdmin();
    }

    match /settings/admins {
      allow read: if signedIn();
      allow write: if isAdmin()
        && request.resource.data.locked == 'admin@istiklalyazilim.com'
        && 'admin@istiklalyazilim.com' in request.resource.data.emails;
    }

    match /settings/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* Mobil panel: elle girilen reklam yatırımı kayıtları. */
    match /settings/adspend {
      allow read, write: if isAdmin();
    }

    match /notes/{id} {
      allow read, write: if isAdmin();
    }

    match /seoPages/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /* Hits retired — GA4 is source of truth. Keep read/delete for admin cleanup. */
    match /hits/{id} {
      allow create: if false;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /stats/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
